# Reference only: load these values through your shell, process manager, or deployment platform.

DATABASE_URL=postgres://postgres:postgres@your-postgres-host:5432/refloyd

# Optional SSL controls for hosted Postgres providers.
# Leave DATABASE_SSL unset to auto-enable SSL for non-local hosts.
# DATABASE_SSL=true
# DATABASE_SSL_REJECT_UNAUTHORIZED=false
# DATABASE_SSL_CA="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# DATABASE_SSL_CA_FILE=/absolute/path/to/ca.pem

APP_ORIGIN=http://localhost:5173

# Optional: set this when the backend is hosted on a different public origin
# than the frontend. Example: https://api.example.com
BACKEND_ORIGIN=

# OIDC turns on automatically when the client ID and issuer/discovery are present.
# You can also force it on explicitly.
OIDC_ENABLED=true

# Set one of these:
OIDC_ISSUER_URL=https://your-idp.example.com
# OIDC_DISCOVERY_URL=https://your-idp.example.com/.well-known/openid-configuration

OIDC_CLIENT_ID=refloyd

# Optional for confidential clients.
OIDC_CLIENT_SECRET=
OIDC_CLIENT_AUTH_METHOD=client_secret_basic

OIDC_SCOPE=openid profile email
OIDC_PROVIDER_NAME=Company SSO
OIDC_SESSION_TTL_HOURS=12
OIDC_SESSION_COOKIE_SAME_SITE=Lax
# If your frontend and backend are on different public origins,
# use None so the browser sends the session cookie on cross-origin API requests.
# OIDC_SESSION_COOKIE_SAME_SITE=None

# Optional extra authorization parameters, encoded as a query string.
# Example: prompt=login&audience=https%3A%2F%2Fapi.example.com
OIDC_AUTHORIZATION_EXTRA_PARAMS=
